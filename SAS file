/* ============================================================
   Diabetes Patient Readmission Risk Analysis (SAS port)
   Direct translation of diabetic_analysis.py + diabetes.sql
   Dataset: Kaggle - Diabetes 130-US Hospitals (1999-2008), 101,766 encounters
   https://www.kaggle.com/datasets/brandao/diabetes
   ============================================================ */

/* 1. Import */
proc import datafile="/data/diabetic_data.csv"
    out=diab
    dbms=csv
    replace;
    getnames=yes;
run;

/* 2. Clean: dataset uses "?" for missing values -> recode to missing */
data diab_clean;
    set diab;
    array charvars _character_;
    do over charvars;
        if charvars = "?" then charvars = "";
    end;
run;

/* Drop columns with too many missing values - not useful for analysis */
data diab_clean;
    set diab_clean(drop = weight payer_code medical_specialty);
run;

/* Keep only first encounter per patient */
proc sort data=diab_clean;
    by patient_nbr;
run;

data diab_clean;
    set diab_clean;
    by patient_nbr;
    if first.patient_nbr;
run;

/* Exclude expired/hospice patients (codes 11,13,14,19,20,21) -
   these patients cannot be readmitted, so they'd distort the rate. */
data diab_final;
    set diab_clean;
    where discharge_disposition_id not in (11, 13, 14, 19, 20, 21);
    readmitted_30days = (readmitted = "<30");
run;

proc sql;
    select count(*) as total_encounters,
           sum(readmitted_30days) as readmitted,
           round(100.0*sum(readmitted_30days)/count(*), 0.01) as readmission_rate_pct
    from diab_final;
quit;

/* 3. Age Group Analysis */
data diab_final;
    set diab_final;
    length age_group $12;
    if age in ("[0-10)") then age_group = "Child";
    else if age in ("[10-20)") then age_group = "Teen";
    else if age in ("[20-30)") then age_group = "Young Adult";
    else if age in ("[30-40)", "[40-50)") then age_group = "Adult";
    else if age in ("[50-60)") then age_group = "Middle Age";
    else if age in ("[60-70)", "[70-80)") then age_group = "Senior";
    else if age in ("[80-90)", "[90-100)") then age_group = "Elderly";
run;

proc sql;
    create table age_summary as
    select age_group,
           count(*) as total,
           sum(readmitted_30days) as readmitted,
           round(100.0*sum(readmitted_30days)/count(*), 0.01) as readmission_rate_pct
    from diab_final
    group by age_group
    order by readmission_rate_pct desc;
quit;

/* 4. Length of Stay */
proc means data=diab_final mean;
    var time_in_hospital;
run;

proc sql;
    create table los_summary as
    select time_in_hospital,
           count(*) as total,
           sum(readmitted_30days) as readmitted,
           round(100.0*sum(readmitted_30days)/count(*), 0.01) as readmission_rate_pct
    from diab_final
    group by time_in_hospital
    order by time_in_hospital;
quit;

/* 5. Admission Type Analysis */
data diab_final;
    set diab_final;
    length admission_type $15;
    if admission_type_id = 1 then admission_type = "Emergency";
    else if admission_type_id = 2 then admission_type = "Urgent";
    else if admission_type_id = 3 then admission_type = "Elective";
    else if admission_type_id = 4 then admission_type = "Newborn";
    else if admission_type_id = 7 then admission_type = "Trauma Center";
    else admission_type = "Other";
run;

proc sql;
    create table adm_summary as
    select admission_type,
           count(*) as total,
           sum(readmitted_30days) as readmitted,
           round(100.0*sum(readmitted_30days)/count(*), 0.01) as readmission_rate_pct
    from diab_final
    group by admission_type
    order by readmission_rate_pct desc;
quit;

/* 6. High Risk Patient Identification - elderly + emergency + long stay (7+ days) */
data diab_final;
    set diab_final;
    high_risk = (age in ("[70-80)", "[80-90)", "[90-100)")
                 and admission_type_id = 1
                 and time_in_hospital >= 7);
run;

proc sql;
    select sum(high_risk) as high_risk_patients,
           round(100.0*sum(case when high_risk=1 then readmitted_30days else 0 end)
                 / sum(high_risk), 0.01) as high_risk_readmission_rate_pct
    from diab_final;
quit;

/* 7. Charts */
proc sgplot data=age_summary;
    hbar age_group / response=readmission_rate_pct;
    title "30-Day Readmission Rate by Age Group";
run;

proc sgplot data=adm_summary;
    vbar admission_type / response=readmission_rate_pct;
    title "Readmission Rate by Admission Type";
run;
